# Copy this file to .env.docker before running Docker Compose.
SERVER_PORT=8080

# Backend -> MySQL service inside Docker Compose
DB_URL=jdbc:mysql://mysql:3306/authentication_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your-db-password

# MySQL container
MYSQL_ROOT_PASSWORD=your-db-password
MYSQL_DATABASE=authentication_db

MAIL_USERNAME=your-email@domain.com
MAIL_PASSWORD=your-mail-app-password

JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Optional when you want to register with a real Eureka server.
EUREKA_URL=https://your-eureka-server/eureka
